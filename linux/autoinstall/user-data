#cloud-config
autoinstall:
  # Current parser version is 1.
  version: 1
  
  refresh-installer:
    update: false

  apt:
    preserve_sources_list: true

  identity:
    hostname: m2
    username: tom
    # Generated with:  openssl passwd -6
    password: "$6$2CkW4gyqnGvQ7nmX$cad4WNt5Vd7Fd/Ubv458zYQCyadUtxWKG63mzswoijGuKjCY9Zt5bs7j/g9SFmgQaL9Jdtsj/b8YIybxcTPPV0"

  locale: en_US
  keyboard:
    layout: us
  
  storage:
    layout:
      name: direct

  packages:
    - openssh-server
    - wpasupplicant

  late-commands:
    - |
      # Create initial netplan file and disiable ethernet links.
      # Uses a en* match which currently matches all ethernet link retruned from
      # Wifi set up from network.sh after first reboot.
      # "ip link" command
      rm /target/etc/netplan/0*.yaml
      tee /target/etc/netplan/01-config.yaml <<EOF
      network:
        version: 2
        renderer: networkd
        ethernets:
          all-en-interfaces:
            match:
              name: "en*"
            dhcp4: true
            optional: true
      EOF

        # Variables
        MOUNT_POINT="/tmp/cidata_mount"
        LABEL="CIDATA"
        CIDATA_PATH=$(findmnt -n -S LABEL=$LABEL -o TARGET | head -n 1)
        MOUNTED_BY_US=false
        
        if [ -z "$CIDATA_PATH" ]; then
            mkdir -p $MOUNT_POINT
            mount -L $LABEL $MOUNT_POINT
            MOUNTED_BY_US=true
            CIDATA_PATH=$MOUNT_POINT
        fi
        
        # Operations (executed inside the same block)
        mkdir -p /target/home/tom/bootstrap
        cp -a $CIDATA_PATH/bootstrap/. /target/home/tom/bootstrap/
        chown -R 1000:1000 /target/home/tom/bootstrap
        chmod +x /target/home/tom/bootstrap/*.sh
        
        # Cleanup (still inside the block)
        if [ "$MOUNTED_BY_US" = true ]; then
            umount $MOUNT_POINT
            rmdir $MOUNT_POINT
        fi

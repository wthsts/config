#cloud-config
autoinstall:
  # Current parser version is 1.
  version: 1
  
  refresh-installer:
    update: false

  apt:
    preserve_sources_list: true

  identity:
    hostname: machine1
    username: tom
    # Generated with:  openssl passwd -6
    password: "$6$2CkW4gyqnGvQ7nmX$cad4WNt5Vd7Fd/Ubv458zYQCyadUtxWKG63mzswoijGuKjCY9Zt5bs7j/g9SFmgQaL9Jdtsj/b8YIybxcTPPV0"

  locale: en_US
  keyboard:
    layout: us
  
  storage:
    layout:
      name: direct

  packages:
    - openssh-server

  late-commands:
    # 1. Disable the service so it does not start automatically
    - curtin in-target -- systemctl disable systemd-networkd-wait-online.service
    # 2. Mask the service to prevent any other service from manually triggering it
    - curtin in-target -- systemctl mask systemd-networkd-wait-online.service

    # 2. Find and mount the CIDATA partition by label
    # This creates a temporary, reliable mount point within the installer environment
    - mkdir -p /tmp/cidata_mount
    - mount -L CIDATA /tmp/cidata_mount
        
    # 3. Ensure the user home exists (if the installer hasn't created it yet)
    - curtin in-target -- mkdir -p /target/home/tom/bootstrap    
    # 4. Copy the files
    - cp -a /tmp/cidata_mount/bootstrap/. /target/home/tom/bootstrap/
    
    # 5. CRITICAL: Fix ownership so the 'tom' user can actually use these files
    # Use 1000 instead of tom.  1000 is id of first user (tom)
    - chown -R 1000:1000 /target/home/tom/bootstrap
    
    # 46. Set permissions
    - chmod +x /target/home/tom/bootstrap/*.sh

    # 7. Cleanup
    - umount /tmp/cidata_mount
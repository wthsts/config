#cloud-config
autoinstall:
  # Current parser version is 1.
  version: 1
  
  refresh-installer:
    update: false

  apt:
    preserve_sources_list: true

  identity:
    hostname: machine1
    username: tom
    password: "$6$IlvreOqXZe49hLSF$iEK0ogiBDU6q/tyJxavT/VujMpS8FjyjUeetWVUwqxvP6ovV7ULXhoyHuslof5iSD912N2ThPa1rWhG0ehEiJ0"

  locale: en_US
  keyboard:
    layout: us
  
  storage:
    layout:
      name: direct

  packages:
    - openssh-server

  late-commands:
    # 1. Disable the service so it does not start automatically
    - curtin in-target -- systemctl disable systemd-networkd-wait-online.service
    # 2. Mask the service to prevent any other service from manually triggering it
    - curtin in-target -- systemctl mask systemd-networkd-wait-online.service

    # 2. Find and mount the CIDATA partition by label
    # This creates a temporary, reliable mount point within the installer environment
    - mkdir -p /tmp/cidata_mount
    - mount -L CIDATA /tmp/cidata_mount
    
    # 3. Now perform the copy using the known /tmp/cidata_mount path
    - mkdir -p /target/opt/bootstrap
    - cp -a /tmp/cidata_mount/bootstrap/. /target/opt/bootstrap/
    
    # 4. Cleanup
    - umount /tmp/cidata_mount